# Server
PORT=4000
CLIENT_ORIGIN=https://student.reactdevacademy.com
CLIENT_RESET_URL=https://student.reactdevacademy.com/reset-password

# Auth
JWT_SECRET=change-this-to-a-long-random-string
SESSION_HOURS=12
RESET_TOKEN_MINUTES=30

# SMTP (example: Gmail app password)
# 1. Enable 2FA on the Gmail account
# 2. Create an "App Password" at https://myaccount.google.com/apppasswords
# 3. Use that 16-character app password below (not your normal Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM="Student Notes <your-email@gmail.com>"

# --- OR use Mailtrap for safe testing (recommended while developing) ---
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_SECURE=false
# SMTP_USER=your-mailtrap-user
# SMTP_PASS=your-mailtrap-pass
# MAIL_FROM="Student Notes <notes@student.mywebsitename.com>"
